{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "SST Template Injection",
  "scopeName": "inline.sst-template",
  "injectionSelector": "L:string.template",
  "patterns": [
    {
      "include": "#sst-component-comment"
    },
    {
      "include": "#sst-interpolation"
    },
    {
      "include": "#js-template-expression"
    },
    {
      "include": "#sst-component-tag"
    },
    {
      "include": "#sst-close-component-tag"
    },
    {
      "include": "#sst-html-tag"
    },
    {
      "include": "#sst-close-tag"
    },
    {
      "include": "#sst-markdown-patterns"
    }
  ],
  "repository": {
    "sst-markdown-patterns": {
      "comment": "Custom single-line markdown patterns. Uses only match (no begin/end) to avoid leaking past template literal boundaries.",
      "patterns": [
        {
          "comment": "Markdown heading: # H1 through ###### H6",
          "match": "^\\s*(#{1,6})\\s+(.+)$",
          "captures": {
            "1": {
              "name": "punctuation.definition.heading.markdown"
            },
            "2": {
              "name": "markup.heading.markdown"
            }
          }
        },
        {
          "comment": "Markdown bold: **text**",
          "match": "(\\*\\*)((?!\\s)[^*]+(?<!\\s))(\\*\\*)",
          "captures": {
            "1": {
              "name": "punctuation.definition.bold.markdown"
            },
            "2": {
              "name": "markup.bold.markdown"
            },
            "3": {
              "name": "punctuation.definition.bold.markdown"
            }
          }
        },
        {
          "comment": "Markdown bold (underscore): __text__",
          "match": "(__)((?!\\s)[^_]+(?<!\\s))(__)",
          "captures": {
            "1": {
              "name": "punctuation.definition.bold.markdown"
            },
            "2": {
              "name": "markup.bold.markdown"
            },
            "3": {
              "name": "punctuation.definition.bold.markdown"
            }
          }
        },
        {
          "comment": "Markdown italic: *text* (not preceded/followed by another *)",
          "match": "(?<!\\*)(\\*)((?!\\s)[^*]+(?<!\\s))(\\*)(?!\\*)",
          "captures": {
            "1": {
              "name": "punctuation.definition.italic.markdown"
            },
            "2": {
              "name": "markup.italic.markdown"
            },
            "3": {
              "name": "punctuation.definition.italic.markdown"
            }
          }
        },
        {
          "comment": "Markdown italic (underscore): _text_",
          "match": "(?<!_)(_)((?!\\s)[^_]+(?<!\\s))(_)(?!_)",
          "captures": {
            "1": {
              "name": "punctuation.definition.italic.markdown"
            },
            "2": {
              "name": "markup.italic.markdown"
            },
            "3": {
              "name": "punctuation.definition.italic.markdown"
            }
          }
        },
        {
          "comment": "Markdown strikethrough: ~~text~~",
          "match": "(~~)((?!\\s)[^~]+(?<!\\s))(~~)",
          "captures": {
            "1": {
              "name": "punctuation.definition.strikethrough.markdown"
            },
            "2": {
              "name": "markup.strikethrough.markdown"
            },
            "3": {
              "name": "punctuation.definition.strikethrough.markdown"
            }
          }
        },
        {
          "comment": "Markdown image: ![alt](url)",
          "match": "(!)(?:(\\[)([^\\]]*)(\\]))(\\()([^)]+)(\\))",
          "captures": {
            "1": {
              "name": "punctuation.definition.image.markdown"
            },
            "2": {
              "name": "punctuation.definition.link.markdown"
            },
            "3": {
              "name": "string.other.link.description.markdown"
            },
            "4": {
              "name": "punctuation.definition.link.markdown"
            },
            "5": {
              "name": "punctuation.definition.link.markdown"
            },
            "6": {
              "name": "markup.underline.link.image.markdown"
            },
            "7": {
              "name": "punctuation.definition.link.markdown"
            }
          }
        },
        {
          "comment": "Markdown link: [text](url)",
          "match": "(\\[)([^\\]]+)(\\])(\\()([^)]+)(\\))",
          "captures": {
            "1": {
              "name": "punctuation.definition.link.markdown"
            },
            "2": {
              "name": "string.other.link.title.markdown"
            },
            "3": {
              "name": "punctuation.definition.link.markdown"
            },
            "4": {
              "name": "punctuation.definition.link.markdown"
            },
            "5": {
              "name": "markup.underline.link.markdown"
            },
            "6": {
              "name": "punctuation.definition.link.markdown"
            }
          }
        },
        {
          "comment": "Markdown blockquote: > text",
          "match": "^\\s*(>)\\s?(.*)",
          "captures": {
            "1": {
              "name": "punctuation.definition.quote.begin.markdown"
            },
            "2": {
              "name": "markup.quote.markdown"
            }
          }
        },
        {
          "comment": "Markdown unordered list item: - item, * item, + item",
          "match": "^\\s*([-*+])\\s",
          "captures": {
            "1": {
              "name": "punctuation.definition.list.begin.markdown"
            }
          }
        },
        {
          "comment": "Markdown ordered list item: 1. item",
          "match": "^\\s*(\\d+\\.)\\s",
          "captures": {
            "1": {
              "name": "punctuation.definition.list.begin.markdown"
            }
          }
        },
        {
          "comment": "Markdown horizontal rule: --- or *** or ___",
          "match": "^\\s*([-*_]{3,})\\s*$",
          "name": "meta.separator.markdown"
        }
      ]
    },
    "sst-component-comment": {
      "comment": "SST component in HTML comment form: <!-- ComponentName attrs / -->",
      "begin": "(<!--)\\s+([A-Z][a-zA-Z0-9]*)\\b",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.comment.begin.html"
        },
        "2": {
          "name": "support.class.component.sst"
        }
      },
      "end": "(/\\s*-->)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.comment.end.html"
        }
      },
      "name": "meta.component-comment.sst",
      "patterns": [
        {
          "include": "#sst-tag-attributes"
        }
      ]
    },
    "sst-interpolation": {
      "comment": "SST double-curly interpolation: {{variableName}} or {{nested.path}}. Uses template-expression scopes to match ${} visual style.",
      "match": "(\\{\\{)([\\w.]+)(\\}\\})",
      "name": "meta.template.expression.sst",
      "captures": {
        "1": {
          "name": "punctuation.definition.template-expression.begin.sst"
        },
        "2": {
          "name": "variable.other.readwrite.sst"
        },
        "3": {
          "name": "punctuation.definition.template-expression.end.sst"
        }
      }
    },
    "js-template-expression": {
      "comment": "Standard JS template expression: ${expression}",
      "begin": "(\\$\\{)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.template-expression.begin.js"
        }
      },
      "end": "(\\})",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.template-expression.end.js"
        }
      },
      "name": "meta.template.expression.js",
      "patterns": [
        {
          "include": "source.js"
        }
      ]
    },
    "sst-event-binding": {
      "comment": "SST event binding: :click=methodName() or :click=methodName(key={{val}}). Uses begin/end to properly parse arguments.",
      "begin": "(:)([a-zA-Z]+)(=)([a-zA-Z_$][a-zA-Z0-9_$]*)(\\()",
      "beginCaptures": {
        "1": {
          "name": "keyword.operator.sst"
        },
        "2": {
          "name": "entity.other.attribute-name.event.sst"
        },
        "3": {
          "name": "keyword.operator.assignment.sst"
        },
        "4": {
          "name": "entity.name.function.sst"
        },
        "5": {
          "name": "meta.brace.round.js"
        }
      },
      "end": "(\\))",
      "endCaptures": {
        "1": {
          "name": "meta.brace.round.js"
        }
      },
      "name": "meta.event-binding.sst",
      "patterns": [
        {
          "include": "#sst-event-arg"
        },
        {
          "include": "#sst-interpolation"
        },
        {
          "include": "#js-template-expression"
        },
        {
          "match": ",",
          "name": "punctuation.separator.comma.sst"
        }
      ]
    },
    "sst-event-arg": {
      "comment": "Event binding argument: key= (before a value like {{val}})",
      "match": "([a-zA-Z_$][a-zA-Z0-9_$]*)(=)(?=[^\"'])",
      "captures": {
        "1": {
          "name": "variable.parameter.sst"
        },
        "2": {
          "name": "keyword.operator.assignment.sst"
        }
      }
    },
    "sst-attr-function-call": {
      "comment": "Function call inside attribute value: functionName() or functionName(args)",
      "match": "([a-zA-Z_$][a-zA-Z0-9_$]*)(\\()(.*?)(\\))",
      "captures": {
        "1": {
          "name": "entity.name.function.sst"
        },
        "2": {
          "name": "meta.brace.round.js"
        },
        "3": {
          "name": "variable.parameter.sst"
        },
        "4": {
          "name": "meta.brace.round.js"
        }
      }
    },
    "sst-tag-attributes": {
      "patterns": [
        {
          "include": "#js-template-expression"
        },
        {
          "include": "#sst-event-binding"
        },
        {
          "include": "#sst-interpolation"
        },
        {
          "comment": "Double-quoted attribute with function call and interpolation support",
          "begin": "([a-zA-Z_-][a-zA-Z0-9_-]*)(=)(\")",
          "beginCaptures": {
            "1": {
              "name": "entity.other.attribute-name.html"
            },
            "2": {
              "name": "punctuation.separator.key-value.html"
            },
            "3": {
              "name": "punctuation.definition.string.begin.html"
            }
          },
          "end": "(\")",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.string.end.html"
            }
          },
          "contentName": "string.quoted.double.html",
          "patterns": [
            {
              "include": "#sst-attr-function-call"
            },
            {
              "include": "#sst-interpolation"
            }
          ]
        },
        {
          "comment": "Single-quoted attribute with function call and interpolation support",
          "begin": "([a-zA-Z_-][a-zA-Z0-9_-]*)(=)(')",
          "beginCaptures": {
            "1": {
              "name": "entity.other.attribute-name.html"
            },
            "2": {
              "name": "punctuation.separator.key-value.html"
            },
            "3": {
              "name": "punctuation.definition.string.begin.html"
            }
          },
          "end": "(')",
          "endCaptures": {
            "1": {
              "name": "punctuation.definition.string.end.html"
            }
          },
          "contentName": "string.quoted.single.html",
          "patterns": [
            {
              "include": "#sst-attr-function-call"
            },
            {
              "include": "#sst-interpolation"
            }
          ]
        },
        {
          "comment": "Standalone attribute name (no value)",
          "match": "[a-zA-Z_-][a-zA-Z0-9_-]*",
          "name": "entity.other.attribute-name.html"
        }
      ]
    },
    "sst-component-tag": {
      "comment": "Component tag (PascalCase): <ComponentName prop=\"val\"/> or <ComponentName>",
      "begin": "(<)([A-Z][a-zA-Z0-9]*)\\b",
      "beginCaptures": {
        "1": {
          "name": "keyword.operator.sst"
        },
        "2": {
          "name": "support.class.component.sst"
        }
      },
      "end": "(/?>)",
      "endCaptures": {
        "1": {
          "name": "keyword.operator.sst"
        }
      },
      "name": "meta.tag.component.sst",
      "patterns": [
        {
          "include": "#sst-tag-attributes"
        }
      ]
    },
    "sst-close-component-tag": {
      "comment": "Closing component tag: </ComponentName>",
      "match": "(</)([A-Z][a-zA-Z0-9]*)(>)",
      "captures": {
        "1": {
          "name": "keyword.operator.sst"
        },
        "2": {
          "name": "support.class.component.sst"
        },
        "3": {
          "name": "keyword.operator.sst"
        }
      }
    },
    "sst-html-tag": {
      "comment": "HTML opening or self-closing tag: <div class=\"x\"> or <img/>",
      "begin": "(<)([a-z][a-zA-Z0-9-]*)\\b",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        }
      },
      "end": "(/?>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.end.html"
        }
      },
      "name": "meta.tag.html",
      "patterns": [
        {
          "include": "#sst-tag-attributes"
        }
      ]
    },
    "sst-close-tag": {
      "comment": "Closing HTML tag: </div>",
      "match": "(</)([a-z][a-zA-Z0-9-]*)(>)",
      "captures": {
        "1": {
          "name": "punctuation.definition.tag.begin.html"
        },
        "2": {
          "name": "entity.name.tag.html"
        },
        "3": {
          "name": "punctuation.definition.tag.end.html"
        }
      }
    }
  }
}